
config interface 'loopback'
	option device 'lo'
	option proto 'static'
	option ipaddr '127.0.0.1'
	option netmask '255.0.0.0'

config globals 'globals'
	option packet_steering '1'
	option dhcp_default_duid '00048d6b76e8febf443ab9dd8416d79d36c6'

config interface 'lan'
	option device 'br-lan.1'
	option proto 'static'
	option ipaddr '192.168.5.1'
	option netmask '255.255.255.0'
	option ip6assign '60'
	option multipath 'off'

config device
	option name 'br-lan'
	option type 'bridge'
	list ports 'lan'

config bridge-vlan
	option device 'br-lan'
	option vlan '1'
	list ports 'lan'

config bridge-vlan
	option device 'br-lan'
	option vlan '42'
	list ports 'lan:t'

config interface 'wan'
	option proto 'dhcp'
	option device 'br-lan.42'

